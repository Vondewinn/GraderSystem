                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/black"
                android:layout_marginLeft="10dp"
                android:textSize="22sp"
                android:layout_marginTop="3dp"
                android:layout_gravity="center_vertical"/>

            <ImageView
